# ─────────────────────────────────────────────────────────────────
#  Sprint-Space — Environment Variables
#  Copy this file to .env and fill in your values.
#  .env is gitignored and will NEVER be pushed to GitHub.
# ─────────────────────────────────────────────────────────────────

# Supabase — get these from: supabase.com → your project → Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here

# Spotify — get this from: developer.spotify.com/dashboard
# Optional — if not set the music player simply won't appear
VITE_SPOTIFY_CLIENT_ID=your-spotify-client-id-here
